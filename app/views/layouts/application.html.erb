<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "きかくさん | ライバーのための配信企画ジェネレータ" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="ライバー向けの配信企画ジェネレータ。ジャンルを選ぶだけでAIがネタを提案。無料・登録不要。">
    <meta name="keywords" content="配信企画,ライバー,REALITY,配信ネタ,きかくさん,Vライバー,雑談,ゲーム配信,うた配信">
    <meta name="robots" content="index, follow">

    <%# OGP %>
    <meta property="og:title" content="きかくさん | ライバーのための配信企画ジェネレータ">
    <meta property="og:description" content="ライバー向けの配信企画ジェネレータ。ジャンルを選ぶだけでAIがネタを提案。無料・登録不要。">
    <meta property="og:type" content="website">
    <meta property="og:image" content="/ogp.png">
    <meta property="og:site_name" content="きかくさん">
    <meta property="og:locale" content="ja_JP">

    <%# Twitter Card %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="きかくさん | ライバーのための配信企画ジェネレータ">
    <meta name="twitter:description" content="ライバー向けの配信企画ジェネレータ。ジャンルを選ぶだけでAIがネタを提案。無料・登録不要。">
    <meta name="twitter:image" content="/ogp.png">

    <meta name="recaptcha-site-key" content="<%= ENV['RECAPTCHA_SITE_KEY'] %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="きかくさん">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Yomogi&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "kikakusan", "data-turbo-track": "reload" %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <% if ENV['RECAPTCHA_SITE_KEY'].present? %>
      <script src="https://www.google.com/recaptcha/api.js?render=<%= ENV['RECAPTCHA_SITE_KEY'] %>"></script>
    <% end %>
    <% if ENV['GA_MEASUREMENT_ID'].present? %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ENV['GA_MEASUREMENT_ID'] %>"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '<%= ENV['GA_MEASUREMENT_ID'] %>');
      </script>
    <% end %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
