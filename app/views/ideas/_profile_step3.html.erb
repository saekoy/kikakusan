<div class="screen" data-ideas-target="screen" data-screen-name="profile-step3">
  <div class="content" style="padding-top:48px;">
    <div class="progress-wrap">
      <div class="progress-dot done"></div>
      <div class="progress-dot done"></div>
      <div class="progress-dot current"></div>
    </div>
    <div class="question-step">STEP 3 / 3</div>
    <div class="question-text">もう少しだけ教えて！</div>
    <div class="question-sub">より自分らしい企画になるよ</div>

    <div class="form-group-label">リスナー層</div>
    <div class="chip-group" data-group="setup-listener">
      <div class="chip" data-action="click->ideas#selectChip">10〜20代が多い</div>
      <div class="chip" data-action="click->ideas#selectChip">幅広い年齢層</div>
      <div class="chip" data-action="click->ideas#selectChip">同世代が多い</div>
      <div class="chip" data-action="click->ideas#selectChip">まだわからない</div>
    </div>

    <div class="form-group-label">自由記入</div>
    <textarea class="home-textarea"
              data-ideas-target="profileMemo"
              placeholder="例：猫を飼ってる、旅行が好き、歌配信をがんばりたい"></textarea>

    <div class="spacer"></div>
    <button class="btn-next"
            data-action="click->ideas#saveProfileFromSetup">
      設定を完了する
    </button>
    <button class="btn-back"
            data-action="click->ideas#showScreen"
            data-ideas-screen-param="profile-step2">
      ← 戻る
    </button>
  </div>
</div>
