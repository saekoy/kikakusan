<div class="screen" data-ideas-target="screen" data-screen-name="home">
  <div class="home-header">
    <div>
      <div class="home-greeting" data-ideas-target="homeGreeting">おつかれ！</div>
      <div class="home-title">今のきぶんを教えてね</div>
    </div>
    <%= image_tag "kuchinashikumasan.png", class: "mini-mascot-img", alt: "きかくさん" %>
  </div>

  <hr class="home-divider">
  <div class="content" style="padding-top:20px;">
    <div class="section-label">ジャンル</div>
    <div class="genre-grid">
      <div class="genre-card"
          data-action="click->ideas#selectGenre"
          data-genre="雑談">
        <span class="g-emoji">💬</span>
        <span class="g-name">ざつだん</span>
      </div>
      <div class="genre-card"
          data-action="click->ideas#selectGenre"
          data-genre="ゲーム">
        <span class="g-emoji">🎮</span>
        <span class="g-name">ゲーム</span>
      </div>
      <div class="genre-card"
          data-action="click->ideas#selectGenre"
          data-genre="歌">
        <span class="g-emoji">🎵</span>
        <span class="g-name">うた</span>
      </div>
      <div class="genre-card"
          data-action="click->ideas#selectGenre"
          data-genre="お任せ">
        <span class="g-emoji">🎲</span>
        <span class="g-name">おまかせ</span>
      </div>
    </div>

    <div class="section-label">きぶん・メモ</div>
    <textarea class="home-textarea"
              data-ideas-target="todayMemo"
              placeholder="・最近ハマってるゲームの新作が出た！テンション高め&#10;・声が出にくい。静かな企画がいい"></textarea>

    <button class="btn-primary"
            data-action="click->ideas#generateIdeas">
      企画を考える
    </button>
  </div>

  <div class="bottom-nav">
    <button class="nav-item active">
      <%= image_tag "illust-house.png", class: "nav-icon-img", alt: "ホーム" %>
      <span>ホーム</span>
    </button>
    <button class="nav-item"
            data-action="click->ideas#showScreen"
            data-ideas-screen-param="profile-edit">
      <%= image_tag "kumatasokao.png", class: "nav-icon-img", alt: "プロフィール" %>
      <span>プロフィール</span>
    </button>
  </div>
</div>
