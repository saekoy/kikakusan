<div class="screen" data-ideas-target="screen" data-screen-name="profile-edit">
  <div class="edit-header">
    <div class="edit-title">プロフィール編集</div>
  </div>

  <div class="content" style="padding-top:12px;">
    <div class="form-group-label">性別</div>
    <div class="chip-group" data-group="edit-gender">
      <div class="chip" data-action="click->ideas#selectChip">女性</div>
      <div class="chip" data-action="click->ideas#selectChip">男性</div>
      <div class="chip" data-action="click->ideas#selectChip">その他</div>
    </div>

    <div class="form-group-label">年齢</div>
    <div class="chip-group" data-group="edit-age">
      <div class="chip" data-action="click->ideas#selectChip">10代前半</div>
      <div class="chip" data-action="click->ideas#selectChip">10代後半</div>
      <div class="chip" data-action="click->ideas#selectChip">20代前半</div>
      <div class="chip" data-action="click->ideas#selectChip">20代後半</div>
      <div class="chip" data-action="click->ideas#selectChip">30代前半</div>
      <div class="chip" data-action="click->ideas#selectChip">30代後半</div>
      <div class="chip" data-action="click->ideas#selectChip">40代前半</div>
      <div class="chip" data-action="click->ideas#selectChip">40代後半</div>
      <div class="chip" data-action="click->ideas#selectChip">50代以上</div>
    </div>

    <div class="form-group-label">家族構成</div>
    <div class="chip-group" data-group="edit-family">
      <div class="chip" data-action="click->ideas#selectChip">一人暮らし</div>
      <div class="chip" data-action="click->ideas#selectChip">実家暮らし</div>
      <div class="chip" data-action="click->ideas#selectChip">パートナーあり</div>
      <div class="chip" data-action="click->ideas#selectChip">子どもあり</div>
    </div>

    <div class="form-group-label">配信キャラクター</div>
    <div class="chip-group" data-group="edit-character">
      <div class="chip" data-action="click->ideas#selectChip">元気・明るい</div>
      <div class="chip" data-action="click->ideas#selectChip">いやし</div>
      <div class="chip" data-action="click->ideas#selectChip">クール</div>
      <div class="chip" data-action="click->ideas#selectChip">イケカテ</div>
      <div class="chip" data-action="click->ideas#selectChip">ネタカテ</div>
    </div>

    <div class="form-group-label">リスナー層</div>
    <div class="chip-group" data-group="edit-listener">
      <div class="chip" data-action="click->ideas#selectChip">10〜20代が多い</div>
      <div class="chip" data-action="click->ideas#selectChip">幅広い年齢層</div>
      <div class="chip" data-action="click->ideas#selectChip">同世代が多い</div>
      <div class="chip" data-action="click->ideas#selectChip">まだわからない</div>
    </div>

    <div class="form-group-label">自由記入（任意）</div>
    <textarea class="home-textarea"
              data-ideas-target="editMemo"
              placeholder="例：大学◯年生、社会人◯年目、猫を飼ってる、旅行が好き、歌配信をがんばりたい"></textarea>

    <div class="spacer"></div>
    <button class="btn-primary"
            data-action="click->ideas#saveProfileFromEdit">
      保存する
    </button>
    <p class="notice">プロフィールはこの端末にのみ保存されます</p>
  </div>

  <div class="bottom-nav">
    <div class="bottom-nav-items">
      <button class="nav-item"
              data-action="click->ideas#showScreen"
              data-ideas-screen-param="home">
        <%= image_tag "illust-house.png", class: "nav-icon-img", alt: "ホーム" %>
        <span>ホーム</span>
      </button>
      <button class="nav-item active">
        <%= image_tag "kumatasokao.png", class: "nav-icon-img", alt: "プロフィール" %>
        <span>プロフィール</span>
      </button>
    </div>
    <div class="app-footer">&copy; 2026 きかくさん</div>
  </div>
</div>
