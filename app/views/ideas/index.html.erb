    <div class="spacer"></div>
    <button class="btn-primary" onclick="saveProfile()">保存する</button>
  </div>
</div>

<script>
  const CHEER_MESSAGES = [
    '今日も配信がんばれ〜！\nきかくさん、応援してるよ🌱',
    'この企画、絶対盛り上がる！\n楽しい配信になりますように✨',
    'いってらっしゃい！\nリスナーさんが待ってるよ🎙️',
    'その企画、好き！\n今日も楽しんでね🎉',
    'きかくさんも一緒に考えたよ！\nいい配信になりますように💪',
  ];

  let selectedGenre = null;
  let selectedIdea = null;

  function showScreen(name) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('screen-' + name).classList.add('active');
  }

  function selectChip(el, groupId) {
    document.querySelectorAll('#' + groupId + ' .chip').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
  }

  function selectGenre(el) {
    document.querySelectorAll('.genre-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    selectedGenre = el.dataset.genre;
  }

  function saveProfileAndComplete() {
    saveProfile();
    showScreen('profile-complete');
  }

  function saveProfile() {
    const profile = {
      nickname: document.getElementById('edit-nickname') ? document.getElementById('edit-nickname').value : getSelectedChip('edit-nickname') || '',
      gender: getSelectedChip('edit-gender-group') || getSelectedChip('gender-group'),
      age: getSelectedChip('edit-age-group') || getSelectedChip('age-group'),
      family: getSelectedChip('edit-family-group') || getSelectedChip('family-group'),
      character: getSelectedChip('edit-character-group') || getSelectedChip('character-group'),
      listener: getSelectedChip('edit-listener-group') || getSelectedChip('listener-group'),
      memo: document.getElementById('edit-memo') ? document.getElementById('edit-memo').value : (document.getElementById('profile-memo') ? document.getElementById('profile-memo').value : ''),
    };
    localStorage.setItem('kikakusan_profile', JSON.stringify(profile));
    updateHomeProfile(profile);
  }

  function getSelectedChip(groupId) {
    const group = document.getElementById(groupId);
    if (!group) return null;
    const selected = group.querySelector('.chip.selected');
    return selected ? selected.textContent : null;
  }

  function updateHomeProfile(profile) {
    if (!profile) return;
    if (profile.nickname) {
      document.getElementById('home-greeting').textContent = profile.nickname + '、おつかれ！';
      const avatar = document.getElementById('user-avatar');
      if (avatar) avatar.textContent = profile.nickname.charAt(0);
    }
    const parts = [profile.age, profile.family, profile.character].filter(Boolean);
    const summary = document.getElementById('user-profile-summary');
    if (summary && parts.length > 0) summary.textContent = parts.join('・');
  }

  function generateIdeas() {
    if (!selectedGenre) {
      alert('ジャンルを選んでね！');
      return;
    }
    showScreen('loading');
    const memo = document.getElementById('today-memo') ? document.getElementById('today-memo').value : '';
    const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

    fetch('/ideas', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify({ category: selectedGenre, memo: memo }),
    })
      .then(res => res.json())
      .then(data => {
        renderIdeas(data.ideas, selectedGenre);
        showScreen('result');
      })
      .catch(() => {
        alert('エラーが発生しました。もう一度試してね。');
        showScreen('home');
      });
  }

  function renderIdeas(ideas, genre) {
    const list = document.getElementById('neta-list');
    const badge = document.getElementById('result-badge');
    if (badge) badge.textContent = genre;
    selectedIdea = null;
    document.getElementById('btn-decide').disabled = true;

    list.innerHTML = ideas.map((idea, i) => `
      <div class="neta-row" onclick="selectNeta(this, '${escapeHtml(idea)}')">
        <div class="neta-num">${i + 1}</div>
        <div class="neta-text">${escapeHtml(idea)}</div>
        <div class="row-actions">
          <button class="copy-btn" onclick="event.stopPropagation(); copyNeta(this, '${escapeHtml(idea)}')">⎘</button>
          <button class="heart-btn" onclick="event.stopPropagation(); toggleHeart(this, '${escapeHtml(idea)}', '${escapeHtml(genre)}')">♡</button>
        </div>
      </div>
    `).join('');
  }

  function escapeHtml(str) {
    return String(str).replace(/[&<>"']/g, m => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]));
  }

  function selectNeta(el, idea) {
    document.querySelectorAll('.neta-row').forEach(r => r.classList.remove('selected'));
    el.classList.add('selected');
    selectedIdea = idea;
    document.getElementById('btn-decide').disabled = false;
  }

  function copyNeta(btn, idea) {
    navigator.clipboard.writeText(idea).then(() => {
      btn.textContent = '✓';
      btn.classList.add('copied');
      const toast = document.getElementById('copy-toast');
      toast.classList.add('show');
      setTimeout(() => {
        toast.classList.remove('show');
        btn.textContent = '⎘';
        btn.classList.remove('copied');
      }, 1500);
    });
  }

  function toggleHeart(btn, idea, genre) {
    btn.classList.toggle('liked');
    const isLiked = btn.classList.contains('liked');
    if (isLiked) {
      const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      fetch('/ideas', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
        body: JSON.stringify({ like: true, title: idea, category: genre }),
      }).catch(() => {});
    }
  }

  function showShareOverlay() {
    if (!selectedIdea) return;
    const cheer = CHEER_MESSAGES[Math.floor(Math.random() * CHEER_MESSAGES.length)];
    document.getElementById('share-cheer').textContent = cheer;
    document.getElementById('share-topic').textContent = selectedIdea;
    document.getElementById('bye-overlay').classList.add('show');
  }

  function shareToX() {
    const text = `今日の配信企画は「${selectedIdea}」🎙️\n#きかくさん #REALITY配信`;
    const url = 'https://twitter.com/intent/tweet?text=' + encodeURIComponent(text);
    window.open(url, '_blank');
  }

  // 初期化：localStorageにプロフィールがあればホームへ
  window.addEventListener('DOMContentLoaded', () => {
    const saved = localStorage.getItem('kikakusan_profile');
    if (saved) {
      const profile = JSON.parse(saved);
      updateHomeProfile(profile);
      showScreen('home');
    }
  });
</script>
