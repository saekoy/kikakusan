<div class="screen" id="screen-profile-edit">
  <div class="edit-header">
    <button class="back-btn" onclick="showScreen('home')">← 戻る</button>
    <div class="edit-title">プロフィール編集</div>
    <div style="width:48px;"></div>
  </div>
  <div class="content" style="padding-top:12px;">
    <div class="form-group-label">ニックネーム</div>
    <input class="big-input" type="text" id="edit-nickname" placeholder="例：さえちゃん">

    <div class="form-group-label">性別</div>
    <div class="chip-group" id="edit-gender-group">
      <div class="chip" onclick="selectChip(this, 'edit-gender-group')">女性</div>
      <div class="chip" onclick="selectChip(this, 'edit-gender-group')">男性</div>
      <div class="chip" onclick="selectChip(this, 'edit-gender-group')">その他</div>
    </div>

    <div class="form-group-label">年齢</div>
    <div class="chip-group" id="edit-age-group">
      <div class="chip" onclick="selectChip(this, 'edit-age-group')">10代前半</div>
      <div class="chip" onclick="selectChip(this, 'edit-age-group')">10代後半</div>
      <div class="chip" onclick="selectChip(this, 'edit-age-group')">20代前半</div>
      <div class="chip" onclick="selectChip(this, 'edit-age-group')">20代後半</div>
      <div class="chip" onclick="selectChip(this, 'edit-age-group')">30代前半</div>
      <div class="chip" onclick="selectChip(this, 'edit-age-group')">30代後半</div>
      <div class="chip" onclick="selectChip(this, 'edit-age-group')">40代前半</div>
      <div class="chip" onclick="selectChip(this, 'edit-age-group')">40代後半</div>
      <div class="chip" onclick="selectChip(this, 'edit-age-group')">50代以上</div>
    </div>

    <div class="form-group-label">家族構成</div>
    <div class="chip-group" id="edit-family-group">
      <div class="chip" onclick="selectChip(this, 'edit-family-group')">一人暮らし</div>
      <div class="chip" onclick="selectChip(this, 'edit-family-group')">実家暮らし</div>
      <div class="chip" onclick="selectChip(this, 'edit-family-group')">パートナーあり</div>
      <div class="chip" onclick="selectChip(this, 'edit-family-group')">子供あり</div>
    </div>

    <div class="form-group-label">配信キャラクター</div>
    <div class="chip-group" id="edit-character-group">
      <div class="chip" onclick="selectChip(this, 'edit-character-group')">ほんわか系</div>
      <div class="chip" onclick="selectChip(this, 'edit-character-group')">元気・明るい系</div>
      <div class="chip" onclick="selectChip(this, 'edit-character-group')">クール・落ち着き系</div>
      <div class="chip" onclick="selectChip(this, 'edit-character-group')">ツッコミ・面白い系</div>
    </div>

    <div class="form-group-label">リスナー層</div>
    <div class="chip-group" id="edit-listener-group">
      <div class="chip" onclick="selectChip(this, 'edit-listener-group')">10〜20代が多い</div>
      <div class="chip" onclick="selectChip(this, 'edit-listener-group')">幅広い年齢層</div>
      <div class="chip" onclick="selectChip(this, 'edit-listener-group')">同世代が多い</div>
      <div class="chip" onclick="selectChip(this, 'edit-listener-group')">まだわからない</div>
