<div class="screen" data-ideas-target="screen" data-screen-name="profile-complete">
  <div class="complete-wrap">
    <div class="complete-emoji">🎉</div>
    <div style="font-size:24px; font-weight:800; color:#111; margin-bottom:10px;">準備完了！</div>
    <div style="font-size:14px; color:#888; line-height:1.8; margin-bottom:48px;">
      プロフィールの設定が<br>終わったよ！<br>さっそく企画を考えてみよう
    </div>
    <button class="btn-primary"
            style="max-width:240px;"
            data-action="click->ideas#showScreen"
            data-ideas-screen-param="home">
      さっそく企画を考えよう →
    </button>
  </div>
</div>
