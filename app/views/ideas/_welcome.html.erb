<div class="screen" data-ideas-target="screen" data-screen-name="welcome">
  <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:24px;">
    <div class="mascot-wrap">
      <div class="thought-bubble">💡</div>
      <div class="kk-char">
        <div class="kk-bun kk-bun-l"></div>
        <div class="kk-bun kk-bun-r"></div>
        <div class="kk-head">
          <div class="kk-hair"></div>
          <div class="kk-eyes">
            <div class="kk-eye"></div>
            <div class="kk-eye"></div>
          </div>
          <div class="kk-mouth"></div>
          <div class="kk-cheek kk-cheek-l"></div>
          <div class="kk-cheek kk-cheek-r"></div>
        </div>
        <div class="kk-body"></div>
      </div>
      <div class="kk-shadow"></div>
    </div>

    <div style="font-size:30px; font-weight:800; color:#111; letter-spacing:2px; margin-bottom:10px;">きかくさん</div>
    <div style="font-size:14px; color:#999; margin-bottom:52px; text-align:center; line-height:1.8;">
      今日の配信企画、<br>まかせて！
    </div>

    <button class="btn-welcome"
            data-action="click->ideas#showScreen"
            data-ideas-screen-param="profile-step1">
      はじめる
    </button>
    <div style="font-size:11px; color:#CCC; margin-top:14px;">ライバーのための企画提案アプリ</div>
  </div>
</div>
