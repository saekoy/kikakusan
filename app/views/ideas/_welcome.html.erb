<div class="screen" data-ideas-target="screen" data-screen-name="welcome">
  <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:24px;">
    <%= image_tag "hirameki-kuma.png", class: "mascot-img", alt: "きかくさん" %>

    <div style="font-size:33px; font-weight:800; color:#111; letter-spacing:2px; margin-bottom:10px;">きかくさん</div>
    <div style="font-size:16px; color:#999; margin-bottom:52px; text-align:center; line-height:1.8;">
      ゆるっと企画を考えるよぉ
    </div>

    <button class="btn-welcome"
            data-action="click->ideas#showScreen"
            data-ideas-screen-param="profile-step1">
      はじめる
    </button>
    <div style="font-size:13px; color:#CCC; margin-top:13px;">ライバーのための企画提案アプリ</div>
  </div>
</div>
