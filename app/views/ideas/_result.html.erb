<div class="screen" data-ideas-target="screen" data-screen-name="result" style="position:relative;">
  <div class="result-header">
    <div class="result-title">きかくさんのアイデア</div>
    <div class="result-badge" data-ideas-target="resultBadge"></div>
  </div>

  <p class="heart-hint">♡を押すと次の提案がよりあなた好みになるよ</p>

  <div class="neta-list" data-ideas-target="netaList">
    <%# 企画リストはJSで動的に生成される %>
  </div>

  <div class="result-footer">
    <button class="btn-decide"
            data-ideas-target="btnDecide"
            data-action="click->ideas#shareToX"
            disabled>
      𝕏 でシェアする
    </button>
    <button class="btn-secondary"
            data-action="click->ideas#generateIdeas">
      もう一回考える
    </button>
  </div>

  <div class="copy-toast" data-ideas-target="copyToast">コピーしました！</div>

  <div class="bottom-nav">
    <div class="bottom-nav-items">
      <button class="nav-item active"
              data-action="click->ideas#showScreen"
              data-ideas-screen-param="home">
        <%= image_tag "illust-house.png", class: "nav-icon-img", alt: "ホーム" %>
        <span>ホーム</span>
      </button>
      <button class="nav-item"
              data-action="click->ideas#showScreen"
              data-ideas-screen-param="profile-edit">
        <%= image_tag "kumatasokao.png", class: "nav-icon-img", alt: "プロフィール" %>
        <span>プロフィール</span>
      </button>
      <button class="nav-item"
              data-action="click->ideas#showScreen"
              data-ideas-screen-param="about">
        <%= image_tag "wa-i-kuma.png", class: "nav-icon-img", alt: "きかくさんとは" %>
        <span>きかくさんとは</span>
      </button>
    </div>
    <div class="app-footer">&copy; 2026 きかくさん</div>
  </div>
</div>
